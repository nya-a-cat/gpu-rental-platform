{
  "name": "@gpu-rental/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "contracts:build": "pnpm --filter @gpu-rental/contracts run build",
    "dev": "vite",

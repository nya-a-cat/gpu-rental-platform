{
  "name": "@gpu-rental/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cli": "tsx src/cli/main.ts",
    "contracts:build": "pnpm --filter @gpu-rental/contracts run build",
    "dev": "tsx watch src/main.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prebuild": "pnpm run contracts:build",
    "precli": "pnpm run contracts:build",
    "predev": "pnpm run contracts:build",
    "prelint": "pnpm run contracts:build",
    "pretest": "pnpm run contracts:build",
    "pretest:e2e": "pnpm run build",
    "pretypecheck": "pnpm run contracts:build",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@gpu-rental/contracts": "workspace:*",
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/mongoose": "11.0.4",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.6",
    "argon2": "0.45.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "cookie-parser": "1.4.7",
    "ioredis": "5.11.1",
    "mongoose": "9.7.4",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.28",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/node": "26.1.1",
    "@types/supertest": "7.2.1",
    "supertest": "7.2.2",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}

{
  "name": "gpu-rental-platform",
  "version": "0.1.0",
  "private": true,
  "description": "GPU Container Cloud control plane with a Go and PostgreSQL production track plus a React and NestJS simulation baseline.",
  "license": "MIT",
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10.34.5 <11"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "control-plane:migrate": "go -C apps/control-plane run ./cmd/migrate up",
    "control-plane:run": "go -C apps/control-plane run ./cmd/control-plane",
    "control-plane:test": "go -C apps/control-plane test ./...",
    "dev": "pnpm --parallel --filter @gpu-rental/api --filter @gpu-rental/web run dev",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "test:e2e": "pnpm --filter @gpu-rental/api run test:e2e",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cli": "pnpm --filter @gpu-rental/api run cli"
  },
  "devDependencies": {
    "prettier": "3.9.5"
  }
}

# Default simulated stack variables. docker-compose.yml uses only this section.
API_PORT=4000
MONGO_DATABASE=gpu_rental
MONGO_ROOT_USERNAME=gpu_app
MONGO_ROOT_PASSWORD=replace_with_a_local_password
MONGO_URI=mongodb://gpu_app:replace_with_a_local_password@localhost:27017/gpu_rental?authSource=admin
REDIS_PASSWORD=replace_with_a_local_password
REDIS_URL=redis://:replace_with_a_local_password@localhost:6379
SESSION_TTL_SECONDS=86400
WEB_ORIGIN=http://localhost:8080
COOKIE_SECURE=false

# v2 control plane and direct Go development only.
# docker-compose.yml does not read or require these values.
POSTGRES_DATABASE=gpu_cloud
POSTGRES_USER=gpu_cloud
POSTGRES_PASSWORD=replace_with_a_local_password
DATABASE_URL=postgres://gpu_cloud:replace_with_a_local_password@localhost:5432/gpu_cloud?sslmode=disable
HTTP_ADDR=:8081
CONTROL_PLANE_VERSION=dev
CONTROL_PLANE_COMMIT=local
BREAK_GLASS_ADMIN_TOKEN=
BREAK_GLASS_ADMIN_SUBJECT=break-glass-admin
SHUTDOWN_TIMEOUT=15s
CONTROL_PLANE_STOP_GRACE_PERIOD=20s
READINESS_TIMEOUT=2s
AGENT_HEARTBEAT_INTERVAL=15s
AGENT_DEGRADED_AFTER=45s
AGENT_OFFLINE_AFTER=90s
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m
MIGRATION_TIMEOUT=5m
MIGRATION_LOCK_TIMEOUT=30s
MIGRATION_STATEMENT_TIMEOUT=2m
OCM_ENABLED=false
OCM_HUB_URL=https://kubernetes.default.svc
OCM_DEFAULT_CLUSTER_ID=
OCM_CA_FILE=/var/run/secrets/kubernetes.io/serviceaccount/ca.crt
OCM_TOKEN_FILE=/var/run/secrets/kubernetes.io/serviceaccount/token
OCM_CLIENT_CERT_FILE=
OCM_CLIENT_KEY_FILE=
OCM_ADDON_INSTALL_NAMESPACE=open-cluster-management-agent-addon
OCM_ADDON_SERVICE_ACCOUNT=gpu-platform-addon-agent
OCM_RECONCILE_TIMEOUT=2m
OCM_POLL_INTERVAL=2s
OCM_MAX_ATTEMPTS=8
